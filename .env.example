# Copy to `.env` and set your TMDb API key (v3 auth from https://www.themoviedb.org/settings/api ).
# Same value as GitHub repository secret `TMDB_API_KEY`.
TMDB_API_KEY=

# Optional: retry TMDb for films with no poster in cache after N days (default 1). Use 0 to retry every run.
# TMDB_EMPTY_POSTER_REFETCH_DAYS=1
